{
  "name": "svelted-component-builder",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "bun run --bun vite dev",
    "build": "bun run vite build",
    "start": "bun message.js && bun run execute",
    "execute": "bun --bun ./build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.15.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/bun": "^1.1.14",
    "@types/eslint": "^8.56.12",
    "@types/three": "^0.159.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "highlight.js": "^11.11.1",
    "phosphor-svelte": "^2.0.1",
    "postcss": "^8.4.49",
    "postcss-load-config": "^5.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "svelte": "^5.0.0",
    "svelte-adapter-bun": "^0.5.2",
    "svelte-check": "^4.0.0",
    "svelte-dnd-action": "^0.9.53",
    "svelte-highlight": "^7.8.1",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "type": "module",
  "dependencies": {
    "@jill64/svelte-sanitize": "^1.3.7",
    "@neodrag/svelte": "^2.2.0",
    "@threlte/core": "^7.3.1",
    "@types/node": "^20.17.10",
    "bits-ui": "^0.21.16",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.17",
    "file-system": "^2.2.2",
    "lucide-svelte": "^0.378.0",
    "mode-watcher": "^0.3.1",
    "svelte-sonner": "^0.3.28",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.2.1",
    "three": "^0.159.0"
  }
}
